# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
dist/
build/

# Entornos virtuales
venv/
.env/
.venv/

# Checkpoints pesados (excluir de Git, incluir estructura)
checkpoints/offline/*.pt
checkpoints/online/*.pt
!checkpoints/**/.gitkeep

