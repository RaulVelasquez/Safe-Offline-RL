# LemgoRL clonado
data/lemgo/

# Resultados intermedios
results/logs/
*.log

# Figuras EPS (archivos grandes, se generan con plot_results.py)
*.eps

# IDE
.vscode/
.idea/
*.swp

# Pytest cache
.pytest_cache/
.coverage
htmlcov/
